<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.fdelorme</groupId>
  <artifactId>demo001</artifactId>
  <name>demo001</name>
  <version>1.0.0</version>
  <description>Animation de vol 3D a travers un champ d'etoiles, rendue en OpenGL ES 3.0 (LWJGL/GLFW).</description>
  <url>https://github.com/fdelorme/demo001</url>
  <developers>
    <developer>
      <name>Frederic Delorme</name>
      <email>frederic.delorme@gmail.com</email>
    </developer>
  </developers>
  <licenses>
    <license>
      <name>MIT License</name>
      <url>https://opensource.org/licenses/MIT</url>
    </license>
  </licenses>
  <build>
    <finalName>${project.artifactId}-${project.version}</finalName>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.15.0</version>
      </plugin>
      <plugin>
        <artifactId>maven-resources-plugin</artifactId>
        <version>3.5.0</version>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.2</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>${main.class}</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.6.3</version>
        <configuration>
          <executable>java</executable>
          <arguments>
            <argument>-Djava.awt.headless=true</argument>
            <argument>--enable-native-access=ALL-UNNAMED</argument>
            <argument>-jar</argument>
            <argument>${project.build.directory}/${project.build.finalName}.jar</argument>
          </arguments>
        </configuration>
      </plugin>
    </plugins>
  </build>
  <profiles>
    <profile>
      <id>linux-amd64</id>
      <properties>
        <jpackage.type>DEB</jpackage.type>
        <lwjgl.natives>natives-linux</lwjgl.natives>
      </properties>
    </profile>
    <profile>
      <id>linux-arm64</id>
      <properties>
        <jpackage.type>DEB</jpackage.type>
        <lwjgl.natives>natives-linux-arm64</lwjgl.natives>
      </properties>
    </profile>
    <profile>
      <id>macos-amd64</id>
      <properties>
        <jpackage.type>DMG</jpackage.type>
        <lwjgl.natives>natives-macos</lwjgl.natives>
      </properties>
    </profile>
    <profile>
      <id>macos-arm64</id>
      <properties>
        <jpackage.type>DMG</jpackage.type>
        <lwjgl.natives>natives-macos-arm64</lwjgl.natives>
      </properties>
    </profile>
    <profile>
      <id>windows-amd64</id>
      <properties>
        <jpackage.type>MSI</jpackage.type>
        <lwjgl.natives>natives-windows</lwjgl.natives>
      </properties>
    </profile>
    <profile>
      <id>windows-arm64</id>
      <properties>
        <jpackage.type>MSI</jpackage.type>
        <lwjgl.natives>natives-windows-arm64</lwjgl.natives>
      </properties>
    </profile>
    <profile>
      <id>installer</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.panteleyev</groupId>
            <artifactId>jpackage-maven-plugin</artifactId>
            <version>1.8.0</version>
            <executions>
              <execution>
                <phase>package</phase>
                <goals>
                  <goal>jpackage</goal>
                </goals>
              </execution>
            </executions>
            <configuration>
              <name>${project.artifactId}</name>
              <appVersion>${project.version}</appVersion>
              <vendor>Frederic Delorme</vendor>
              <copyright>Copyright (c) 2026 Frederic Delorme</copyright>
              <destination>${project.build.directory}/installer</destination>
              <input>${project.build.directory}</input>
              <mainJar>${project.build.finalName}.jar</mainJar>
              <mainClass>${main.class}</mainClass>
              <type>${jpackage.type}</type>
              <javaOptions>
                <option>-Djava.awt.headless=true</option>
                <option>--enable-native-access=ALL-UNNAMED</option>
              </javaOptions>
              <linuxPackageName>demo001</linuxPackageName>
              <linuxAppCategory>Game</linuxAppCategory>
              <linuxShortcut>true</linuxShortcut>
              <linuxMenuGroup>Games</linuxMenuGroup>
              <linuxDebMaintainer>frederic.delorme@gmail.com</linuxDebMaintainer>
              <macPackageName>demo001</macPackageName>
              <macPackageIdentifier>com.fdelorme.demo001</macPackageIdentifier>
              <macAppCategory>public.app-category.action-games</macAppCategory>
              <winMenu>true</winMenu>
              <winShortcut>true</winShortcut>
              <winDirChooser>true</winDirChooser>
              <winUpgradeUuid>8f2f0a2e-9d3b-4e7a-9d0a-1a2b3c4d5e6f</winUpgradeUuid>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
  <properties>
    <maven.compiler.release>26</maven.compiler.release>
    <jpackage.type>DEB</jpackage.type>
    <main.class>Main</main.class>
    <lwjgl.natives>natives-linux-arm64</lwjgl.natives>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <lwjgl.version>3.3.6</lwjgl.version>
  </properties>
</project>
